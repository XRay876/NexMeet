{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "rooms-route": {
        "ClusterId": "rooms-cluster",
        "Match": { "Path": "/api/rooms/{**catch-all}" }
      },
      "messages-api-route": {
        "ClusterId": "messages-cluster",
        "Match": { "Path": "/api/files/{**catch-all}" }
      },
      "history-api-route": {
        "ClusterId": "messages-cluster",
        "Match": { "Path": "/api/history/{**catch-all}" }
      },
      "chat-hub-route": {
        "ClusterId": "messages-cluster",
        "Match": { "Path": "/hubs/chat/{**catch-all}" }
      },
      "signaling-api-route": {
        "ClusterId": "signaling-cluster",
        "Match": { "Path": "/api/signaling/{**catch-all}" }
      },
      "signaling-hub-route": {
        "ClusterId": "signaling-cluster",
        "Match": { "Path": "/hubs/signaling/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": { "destination1": { "Address": "http://identity-service:8080" } }
      },
      "rooms-cluster": {
        "Destinations": { "destination1": { "Address": "http://rooms-service:8080" } }
      },
      "messages-cluster": {
        "Destinations": { "destination1": { "Address": "http://messages-service:8080" } }
      },
      "signaling-cluster": {
        "Destinations": { "destination1": { "Address": "http://signaling-service:8080" } }
      }
    }
  }
}